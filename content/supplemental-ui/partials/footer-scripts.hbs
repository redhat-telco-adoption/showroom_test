<script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
  const images = document.querySelectorAll('.doc .imageblock img');
  if (!images.length) return;

  const elements = Array.from(images).map(function (img) {
    return { href: img.src, type: 'image', alt: img.alt };
  });

  const lightbox = GLightbox({ elements: elements, touchNavigation: true });

  images.forEach(function (img, i) {
    img.addEventListener('click', function () {
      lightbox.openAt(i);
    });
  });
});
</script>
